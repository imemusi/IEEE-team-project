rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // Q&A collection — class-scoped
    match /classes/{classId}/qa/{questionId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthed();
      allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;

      match /replies/{replyId} {
        allow read: if isAuthed();
        allow create: if isAuthed() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;
      }
    }

    // Legacy flat Q&A (keep for backwards compat)
    match /qa/{questionId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthed();
      allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;

      // replies subcollection
      match /replies/{replyId} {
        allow read: if isAuthed();
        allow create: if isAuthed() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;
      }
    }

    // Study sessions (class-scoped)
    match /classes/{classId}/sessions/{sessionId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed() && resource.data.hostId == request.auth.uid;

      match /messages/{msgId} {
        allow read: if isAuthed();
        allow create: if isAuthed();
        allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;
      }
    }

    // Class chat — scoped per class under classes/{classId}/chat
    match /classes/{classId}/chat/{msgId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed() && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;

      match /replies/{replyId} {
        allow read: if isAuthed();
        allow create: if isAuthed();
        allow update: if isAuthed() && resource.data.authorId == request.auth.uid;
        allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;
      }
    }

    // Legacy flat classChat (keep for backwards compat)
    match /classChat/{msgId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed() && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthed() && resource.data.authorId == request.auth.uid;

      match /replies/{replyId} {
        allow read: if isAuthed();
        allow create: if isAuthed();
        allow update: if isAuthed() && resource.data.authorId == request.auth.uid;
      }
    }

    // Class-scoped resources metadata
    match /classes/{classId}/resources/{resId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if isAuthed() && resource.data.uploaderId == request.auth.uid;
    }

    // Legacy flat resources (backwards compat)
    match /resources/{resId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if isAuthed() && resource.data.uploaderId == request.auth.uid;
    }

    // Fallback: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
